{
  "Component Scaffold": {
    "prefix": "comp",
    "body": [
      "import { SwissComponent } from '@swissjs/core';",
      "",
      "component ${1:MyComponent} {",
      "  props = {",
      "    ${2:label}: string;",
      "  };",
      "",
      "  state {",
      "    let ${3:value}: ${4:string} = ${5:''};",
      "  }",
      "",
      "  mounted() {",
      "    $6",
      "  }",
      "",
      "  render() {",
      "    return (",
      "      <div>",
      "        $7",
      "      </div>",
      "    );",
      "  }",
      "}"
    ],
    "description": "Full SwissJS component with props, state, mounted, and render"
  },

  "Component Simple": {
    "prefix": "comps",
    "body": [
      "import { SwissComponent } from '@swissjs/core';",
      "",
      "component ${1:MyComponent} {",
      "  render() {",
      "    return (",
      "      <div>",
      "        $2",
      "      </div>",
      "    );",
      "  }",
      "}"
    ],
    "description": "Minimal SwissJS component with just a render method"
  },

  "State Block": {
    "prefix": "state",
    "body": [
      "state {",
      "  let ${1:loading}: boolean = false;",
      "  let ${2:data}: any = null;",
      "  let ${3:error}: string = '';",
      "}"
    ],
    "description": "SwissJS reactive state block"
  },

  "Props Declaration": {
    "prefix": "props",
    "body": [
      "props = {",
      "  ${1:label}: string;",
      "  ${2:value}?: ${3:number};",
      "};"
    ],
    "description": "SwissJS component props declaration"
  },

  "Mounted Hook": {
    "prefix": "mounted",
    "body": [
      "async mounted() {",
      "  try {",
      "    const res = await fetch('${1:/api/endpoint}');",
      "    this.${2:data} = await res.json();",
      "  } catch (e: any) {",
      "    this.${3:error} = e.message;",
      "  } finally {",
      "    this.${4:loading} = false;",
      "  }",
      "}"
    ],
    "description": "Async mounted lifecycle hook with fetch pattern"
  },

  "Destroyed Hook": {
    "prefix": "destroyed",
    "body": [
      "destroyed() {",
      "  $1",
      "}"
    ],
    "description": "SwissJS destroyed lifecycle hook for cleanup"
  },

  "Helper Method": {
    "prefix": "_m",
    "body": [
      "_${1:methodName}(${2:param}: ${3:string}): ${4:string} {",
      "  return $5;",
      "}"
    ],
    "description": "SwissJS helper method (prefixed with _)"
  },

  "List Render": {
    "prefix": "map",
    "body": [
      "{this.${1:items}.map((${2:item}: any) => (",
      "  <div key={${2:item}.${3:id}}>",
      "    {${2:item}.${4:name}}",
      "  </div>",
      "))}"
    ],
    "description": "JSX list render with .map()"
  },

  "Conditional And": {
    "prefix": "ifa",
    "body": [
      "{this.${1:condition} && (",
      "  <div>$2</div>",
      ")}"
    ],
    "description": "JSX conditional render with &&"
  },

  "Ternary Render": {
    "prefix": "tern",
    "body": [
      "{this.${1:condition} ? (",
      "  <div>$2</div>",
      ") : (",
      "  <div>$3</div>",
      ")}"
    ],
    "description": "JSX ternary conditional"
  },

  "Signal": {
    "prefix": "signal",
    "body": [
      "import { Signal } from '@swissjs/core';",
      "",
      "export const ${1:myValue}$$ = new Signal<${2:string}>('${3:}');"
    ],
    "description": "SwissJS global Signal"
  },

  "Fetch Pattern": {
    "prefix": "fetchm",
    "body": [
      "state {",
      "  let ${1:items}: any[] = [];",
      "  let loading: boolean = true;",
      "  let error: string = '';",
      "}",
      "",
      "async mounted() {",
      "  try {",
      "    const res = await fetch('${2:/api/items}');",
      "    if (!res.ok) throw new Error(res.statusText);",
      "    this.${1:items} = await res.json();",
      "  } catch (e: any) {",
      "    this.error = e.message;",
      "  } finally {",
      "    this.loading = false;",
      "  }",
      "}"
    ],
    "description": "Full fetch-in-mounted pattern with loading/error/data state"
  },

  "SVG Data URI Helper": {
    "prefix": "svguri",
    "body": [
      "_svgDataUrl(path: string): string {",
      "  const svg = '<svg xmlns=\"http://www.w3.org/2000/svg\" width=\"${1:16}\" height=\"${1:16}\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\"><path d=\"' + path + '\" /></svg>';",
      "  return 'data:image/svg+xml;utf8,' + encodeURIComponent(svg);",
      "}"
    ],
    "description": "SVG data URI helper — use <img src={this._svgDataUrl(path)}> (inline SVG is invisible in SwissJS)"
  }
}
